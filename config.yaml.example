# NOTE:
# - This file is a documented template. Copy it to `config.yaml` and fill secrets via env vars.
# - Do NOT commit real API keys/tokens.
#
# Units:
# - *_min = minutes
# - *_sec = seconds

runtime:
  # Fallback subfolder when project_root is empty.
  project_name: ml_project
  # Preferred absolute/relative run root for artifacts/logs/state.
  # If empty, run root becomes <cwd>/<project_name>.
  project_root: ""
  # Create virtual environment automatically on startup.
  create_env: true

  # Base timeouts for code and pip operations.
  code_timeout_min: 30
  pip_timeout_min: 10
  # Extra % used by predictive timeout monitor.
  predictive_buffer_pct: 20

  # Caps/limits used by pipeline loops and checker steps.
  checker_timeout_cap_sec: 60
  verifier_timeout_cap_sec: 60
  default_task_budget_sec: 1800
  prediction_fallback_sec: 300
  min_exec_timeout_sec: 10
  bash_timeout_sec: 600
  metric_validation_retry_limit: 3
  router_retry_limit: 10
  generation_retry_limit: 20
  execution_output_shorten_threshold: 16000
  execution_output_shorten_target: 10000
  replan_context_chars: 5000
  aggregate_tail_chars: 20000
  attach_hardware_limit_files: 3000

paths:
  # Relative paths are resolved under runtime.project_name.
  artifacts_dir: artifacts
  data_dir: data
  # Canonical submission: <project_root>/submission.csv (use empty submission_dir).
  submission_dir: ""
  submission_filename: submission.csv
  logs_dir: logs
  scripts_dir: scripts
  src_dir: src
  tests_dir: tests
  venv_dir: .venv

proxy:
  http: ""
  https: ""
  # If traffic goes through a corporate proxy, set these. For MITM proxies you usually still need
  # the company root CA installed in the OS; disabling verification is a last resort (see llm.disable_ssl).

hardware:
  require_cuda: false
  fail_if_no_cuda: false
  # Example: "0" or "0,1"
  cuda_devices: "0"

llm:
  # one of: openai | anthropic | google | vertex | ollama
  prefer: openai
  # Token cost estimates (USD); same directory as this config file. Edit llm_model_pricing.json in repo root.
  model_pricing_file: llm_model_pricing.json

  # --- TLS / certificate verification (LLM HTTP clients) ---
  # false (default): normal certificate check.
  # true: disable verification — same idea as curl -k / PYTHONHTTPSVERIFY=0 for this process.
  #
  # What actually happens in code (build_llms):
  # - Always: Python's ssl._create_default_https_context is switched to unverified when true
  #   (affects many HTTPS stacks in the same process).
  # - OpenAI / custom base_url: httpx.Client(verify=False) is passed into ChatOpenAI.
  # - Anthropic: httpx.Client(verify=False) passed as http_client into ChatAnthropic.
  # - Google Gemini / Vertex / Ollama: rely on the global ssl patch + SDK defaults (no extra httpx in factory).
  #   If SSL still fails, install corporate root CA
  #   or use REQUESTS_CA_BUNDLE / SSL_CERT_FILE pointing at your PEM bundle.
  # SECURITY: only for debugging or strictly trusted networks.
  # RU: «Выключить проверку сертификата» — поставьте disable_ssl: true (осторожно, не для прода).
  disable_ssl: false

  openai:
    api_key: "${OPENAI_API_KEY}"
    base_url: "https://api.openai.com/v1"
    chat_model_strong: gpt-4o
    chat_model_fast: gpt-4o-mini
    temperature: 0.3
  anthropic:
    api_key: "${ANTHROPIC_API_KEY}"
    base_url: "https://api.anthropic.com"
    chat_model_strong: "claude-3-5-sonnet-20241022"
    chat_model_fast: "claude-3-haiku-20240307"
    temperature: 0.3
  google:
    api_key: "${GOOGLE_API_KEY}"
    cse_id: "${GOOGLE_CSE_ID}"
    application_credentials: "${GOOGLE_APPLICATION_CREDENTIALS}"
    model_flash: "gemini-2.5-flash"
    model_pro: "gemini-2.5-pro"
    temperature: 0.2
  vertex:
    project_id: "${GOOGLE_CLOUD_PROJECT}"
    location: "us-central1"
    model_flash: "gemini-2.5-flash"
    model_pro: "gemini-2.5-pro"
    temperature: 0.2
    application_credentials: "${GOOGLE_APPLICATION_CREDENTIALS}"
  ollama:
    # Local LLM; usually http:// — no TLS. If you use https:// to Ollama, corporate MITM may need
    # disable_ssl: true or a proper CA (same as other providers).
    enabled: false
    base_url: "http://127.0.0.1:11434"
    model: "deepcoder"
    temperature: 0.4

mcp:
  enabled: false
  servers:
    # Example:
    # - name: context7
    #   command: "context7"
    #   args: []
    #   env:
    #     CONTEXT7_API_KEY: "${CONTEXT7_API_KEY}"
    []

orchestration:
  enforce_single_stack: true
  allow_ensembles: true
  metric_source: auto
  require_metrics_json: true
  check_fail_threshold: 0.2
  min_metric_improvement_rel: 0.01
  optimize_iters: 4

  # Tree controls:
  # max_tree_width: max children per node (root included); enforced in code, not prompt-only.
  # min_remaining_sec_to_split: below this remaining global time, tasks run as leaves (no new split).
  max_tree_width: 4
  max_tree_depth: 5
  min_remaining_sec_to_split: 600
  # Improve loop: max YAML tasks per iteration after ordering (also capped by max_tree_width).
  max_improve_tasks_per_iter: 7

  # Improver ReAct meta-planner (deep task discovery inside improvement loop).
  # meta_planner_time_pct: fraction of remaining improve budget reserved for meta-planning.
  # meta_planner_max_attempts: how many times to retry meta-planning when output is invalid.
  meta_planner_time_pct: 0.25
  meta_planner_max_attempts: 3

  # Verifier limits used in main/improve branches.
  main_verifier_max_steps: 15
  improve_verifier_max_steps: 10

  # Global wall-clock budget.
  total_budget_min: 480
  improve_budget_min: 120

preinstall:
  # If false: bootstrap installation step is skipped entirely.
  enable: true
  # Packages installed before pipeline starts.
  # Add torch packages here only if you explicitly want them installed.
  # Example:
  #   - torch
  #   - torchvision
  #   - torchaudio
  pkgs:
    - pandas
    - scikit-learn
    - numpy<2.0
    - langchain-anthropic
  # Used only when preinstall.pkgs contains torch/torchvision/torchaudio.
  # Keep empty to use default PyPI index.
  torch_cuda_index_url: "https://download.pytorch.org/whl/cu121"

data_check:
  enabled: true
  max_samples_per_dir: 4
  probe_timeout_sec: 180
  # Outer rounds for dataset ReAct tool-calling probe (dataset_react_probe in dataset_checker.py).
  react_max_rounds: 3